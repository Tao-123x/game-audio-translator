# Google Cloud service account JSON key path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Audio device index (run: python -c "import sounddevice; print(sounddevice.query_devices())")
# On macOS dev: use default input (0)
# On Windows: use VoiceMeeter output device index
AUDIO_DEVICE_INDEX=0

# WebSocket server port
WS_PORT=8765

# HTTP server port (serves phone UI)
HTTP_PORT=8080

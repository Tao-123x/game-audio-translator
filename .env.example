# Google Cloud service account JSON key path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Audio device index (optional)
# Leave empty to auto-detect: WASAPI loopback on Windows, default mic on macOS/Linux
# To override: run `python server/audio_capture.py` to list devices, then set the index here
# AUDIO_DEVICE_INDEX=0

# WebSocket server port
WS_PORT=8765

# HTTP server port (serves phone UI)
HTTP_PORT=8080
